APP_NAME=GeoAI Risk Engine
DEBUG=true

DATABASE_URL=postgresql+asyncpg://geoai:geoai@localhost:5432/geoai

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

MAPILLARY_ACCESS_TOKEN=your-mapillary-token
ORS_API_KEY=your-openrouteservice-key
GEONAMES_USERNAME=your-geonames-username
ELEVATION_OPENTOPODATA_DATASET=srtm90m
ELEVATION_OPENTOPOGRAPHY_DEMTYPE=SRTMGL1
# this part may used later not now:
# ELEVATION_OPENTOPODATA_DATASET one of:
# srtm30m,srtm90m,aster30m,etopo1,eudem25m,mapzen,ned10m,nzdem8m,emod2018,gebco2020,bkg200m,swisstopo

WEATHER_PROVIDER=open_meteo
OPENWEATHER_API_KEY=

DEM_PROVIDER=srtm

# Options: null | hecras
SIMULATION_ENGINE=null
HECRAS_MCP_URL=http://localhost:8001

# Groq assistant
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Options: clip | mock
CV_MODEL=mock

OPENTOPOGRAPHY_API_KEY=your_key_here
REDIS_URL=redis://localhost:6379